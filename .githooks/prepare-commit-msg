#!/usr/bin/env bash
#
# prepare-commit-msg
# staged diff를 claude -p 로 분석해 Conventional Commits 메시지를 자동 생성한다.
#

COMMIT_MSG_FILE="$1"
COMMIT_SOURCE="$2"

# merge, squash, -m 옵션 등 이미 메시지가 지정된 경우 스킵
if [ -n "$COMMIT_SOURCE" ]; then
    exit 0
fi

# claude CLI가 PATH에 없으면 조용히 스킵
if ! command -v claude &>/dev/null; then
    exit 0
fi

# staged 변경사항 수집
DIFF=$(git diff --cached)

# staged diff가 비어있으면 스킵
if [ -z "$DIFF" ]; then
    exit 0
fi

# 500줄 이상이면 stat만 사용
DIFF_LINES=$(echo "$DIFF" | wc -l | tr -d ' ')
if [ "$DIFF_LINES" -gt 500 ]; then
    DIFF=$(git diff --cached --stat)
fi

# claude -p 로 커밋 메시지 생성
GENERATED=$(echo "$DIFF" | claude -p "
다음은 git staged diff 또는 diff stat이다.
이 변경사항을 분석해서 아래 규칙에 맞는 git 커밋 메시지를 작성해라.

규칙:
1. 형식: Conventional Commits (feat / fix / refactor / chore / docs / test / style)
2. 제목: 한글, 50자 이내, 마침표 없음, 명령형 동사로 시작 (추가, 수정, 제거, 개선)
3. 본문: 2-3줄, '무엇을'이 아니라 '왜' 변경했는지 작성
4. 제목과 본문 사이 빈 줄 하나
5. 커밋 메시지만 출력하고 설명 없이 종료

예시:
feat: 할 일 목록 조회 API 추가

할 일의 상태별 필터링과 페이지네이션을 지원하기 위해
목록 조회 엔드포인트를 추가했다.
" 2>/dev/null)

# 생성 실패 시 조용히 스킵
if [ -z "$GENERATED" ]; then
    exit 0
fi

# 기존 커밋 메시지 파일 내용 읽기
EXISTING=$(cat "$COMMIT_MSG_FILE")

# 생성된 메시지를 앞에 삽입
printf '%s\n\n%s\n' "$GENERATED" "$EXISTING" > "$COMMIT_MSG_FILE"
